<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ProtocolEditorPage</class>
 <widget class="QWidget" name="ProtocolEditorPage">
  <layout class="QVBoxLayout" name="rootLayout">
   <property name="spacing"><number>10</number></property>
   <property name="leftMargin"><number>12</number></property>
   <property name="topMargin"><number>12</number></property>
   <property name="rightMargin"><number>12</number></property>
   <property name="bottomMargin"><number>12</number></property>

   <!-- 标题 -->
   <item>
    <widget class="QLabel" name="titleLabel">
     <property name="text"><string>协议编辑（Web 编辑 → SQLite → 生成 .bin → Qt 加载）</string></property>
    </widget>
   </item>

   <!-- 说明 -->
   <item>
    <widget class="QLabel" name="hintLabel">
     <property name="text"><string>协议编辑已迁移至 Web。点击下方按钮在系统浏览器中打开编辑器；编辑保存后，回到这里下载最新 .bin 并加载。</string></property>
     <property name="wordWrap"><bool>true</bool></property>
    </widget>
   </item>

   <!-- 顶部：打开 Web 编辑器 + 后端状态 -->
   <item>
    <layout class="QHBoxLayout" name="topBar">
     <item><widget class="QPushButton" name="openWebButton"><property name="text"><string>打开 Web 编辑器</string></property></widget></item>
     <item><spacer name="topBarSpacer"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property></spacer></item>
     <item><widget class="QLabel" name="backendStatus"><property name="text"><string>后端：未检测</string></property></widget></item>
    </layout>
   </item>

   <!-- 协议选择区 -->
   <item>
    <widget class="QGroupBox" name="selectGroup">
     <property name="title"><string>从后端加载 .bin</string></property>
     <layout class="QHBoxLayout" name="selectLayout">
      <item><widget class="QLabel" name="protocolLabel"><property name="text"><string>协议：</string></property></widget></item>
      <item><widget class="QComboBox" name="protocolCombo"/></item>
      <item><widget class="QPushButton" name="refreshButton"><property name="text"><string>刷新列表</string></property></widget></item>
      <item><widget class="QPushButton" name="downloadButton"><property name="text"><string>下载并加载 .bin</string></property></widget></item>
      <item><spacer name="selectSpacer"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property></spacer></item>
     </layout>
    </widget>
   </item>

   <!-- 状态/摘要 -->
   <item>
    <widget class="QLabel" name="summaryLabel">
     <property name="text"><string>提示：先点“打开 Web 编辑器”在浏览器里编辑，保存后回到这里下载 .bin。</string></property>
     <property name="wordWrap"><bool>true</bool></property>
     <property name="textInteractionFlags"><set>Qt::TextSelectableByMouse</set></property>
    </widget>
   </item>

   <item><spacer name="verticalSpacer"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer></item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
